      "errors": [
        {
          "code": -31999,
		  "message": "Thing unavailable",
		  "data": {"retry": true}
        }
      ],
      "links": [
        {
          "name": {"relation": "next"},
          "summary": "Next thing",
          "description": "Reads the next thing",
          "method": "things.read",
          "params": {"id": "$result.next"},
          "server": {
            "url": "https://example.com/rpc",
            "name": "Linked",
            "summary": "Linked server",
            "description": "Link destination",
            "variables": {},
            "x-server": true
          },
          "x-link": true
        }
      ],
      "examples": [
        {
          "name": "read example",
          "description": "Complete request and response",
          "params": [
            {
              "name": "id",
              "summary": "Example identifier",
              "description": "Example input",
              "value": "thing-1",
              "vendorExample": true
            }
          ],
          "result": {
            "name": "thing",
            "summary": "Example result",
            "description": "Example output",
            "value": {"id": "thing-1"},
            "vendorExample": true
          },
          "vendorPairing": true
        }
      ],
      "deprecated": false,
      "externalDocs": {
        "description": "Method documentation",
        "url": "https://example.com/methods/read",
        "x-docs": true
      },
      "x-method": true
    }
