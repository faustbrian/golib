  "methods": [
    {
      "name": "things.read",
      "summary": "Read a thing",
      "description": "Reads one thing",
      "servers": [
        {
          "url": "../rpc",
          "name": "Relative",
          "summary": "Relative server",
          "description": "Resolved by the consumer",
          "variables": {},
          "x-server": true
        }
      ],
      "tags": [
        {
          "name": "things",
          "description": "Thing operations",
          "externalDocs": {
            "description": "Tag documentation",
            "url": "https://example.com/tags/things",
            "x-docs": true
          },
          "x-tag": true
        }
      ],
      "params": [
        {
          "name": "id",
          "summary": "Thing identifier",
